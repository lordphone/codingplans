# Copy to ".env" at the repo root (same level as web/ and benchmarks/).
# Never commit real keys. python-dotenv loads .env for local Python benchmarks.

# --- Hugging Face (gated datasets, e.g. GPQA for lm-eval) ---
# Create a read token at https://huggingface.co/settings/tokens
# Accept the dataset license on the Hub before downloading.
HF_TOKEN=hf_replace_me
# HUGGING_FACE_HUB_TOKEN=hf_replace_me

# --- Alibaba Coding Plan / DashScope (Anthropic Messages x-api-key for GPQA runner) ---
CODING_PLAN_API_KEY=sk_replace_me
# LLM_API_KEY=sk_replace_me
# ANTHROPIC_API_KEY=sk_replace_me

# --- Optional: GPQA HTTP timeout (seconds) ---
# LLM_TIMEOUT_S=120

# --- TPS benchmark: single-run mode (no providers.json) ---
# LLM_API_KEY=sk_replace_me
# OPENAI_API_KEY=sk_replace_me
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_PROMPT=Write a short paragraph about token throughput.
# LLM_STREAM_USAGE=false

# --- TPS benchmark: matrix mode ---
# BENCHMARK_CONFIG=benchmarks/providers.json
# BENCHMARK_SLEEP_BETWEEN_JOBS=5

# --- Angular / Supabase (browser reads; usually set in web/src/environments/*.ts instead) ---
# Not required for Python benchmarks.
