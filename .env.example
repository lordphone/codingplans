# Copy to `.env` in the repo root. Real `.env` is gitignored.
# python-dotenv loads `.env` when you run `benchmarks/performance/benchmark.py`.

# API keys referenced by `api_key_env` in benchmarks/providers.json (never commit keys).
# Example provider block uses:
ALIBABA_CLOUD_MODEL_STUDIO_CODING_PLAN_API_KEY=

# Optional: fixed pause between jobs (seconds); overrides JSON unless you use CLI flags
# BENCHMARK_SLEEP_BETWEEN_JOBS=
