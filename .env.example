# Copy to `.env` in the repo root. Real `.env` is gitignored.
# python-dotenv loads `.env` for `benchmarks/performance/benchmark.py`,
# `check_credentials.py`, and `benchmarks/quantization/gpqa/run_gpqa_diamond.py`.

# --- Hugging Face (gated datasets, e.g. GPQA for lm-eval) ---
# Token: https://huggingface.co/settings/tokens — accept dataset licenses on the Hub first.
HF_TOKEN=hf_replace_me
# HUGGING_FACE_HUB_TOKEN=hf_replace_me

# --- Alibaba Model Studio / Coding Plan (benchmarks + GPQA lm-eval use the same x-api-key) ---
# Name matches `api_key_env` in benchmarks/providers.json.
ALIBABA_CLOUD_MODEL_STUDIO_CODING_PLAN_API_KEY=
# Optional overrides for GPQA only:
# ANTHROPIC_API_KEY=
# LLM_API_KEY=

# --- Optional: GPQA HTTP timeout (seconds) ---
# LLM_TIMEOUT_S=120

# --- TPS benchmark: optional pause between matrix jobs (seconds) ---
# BENCHMARK_SLEEP_BETWEEN_JOBS=

# --- TPS single-run mode (no providers.json matrix) — rarely used ---
# LLM_API_KEY=sk_replace_me
# OPENAI_API_KEY=sk_replace_me
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_STREAM_USAGE=false

# Angular / Supabase keys live in web/src/environments/*.ts for the app (not here).
